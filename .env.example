# Database
POSTGRES_USER=aep
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aep
DATABASE_URL=postgres://aep:changeme@db:5432/aep

# Server
MASTER_KEY=replace_with_64_hex_chars_from_openssl_rand_hex_32
PORT=3001

# Data path (host path for agent workspace volumes)
DATA_HOST_PATH=/opt/aep/data

# Internal Docker network name
AEP_NETWORK=aep-network

# Agent runtime image
AGENT_IMAGE=aep-agent-runtime:latest
